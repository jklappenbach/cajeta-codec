package dev.cajeta.codec.tools;

import dev.cajeta.codec.compress.Deflate;
import cajeta.io.file.File;
import cajeta.io.file.FileWriter;
import cajeta.io.file.OpenMode;
import cajeta.lang.String;

/** Emits /tmp/our_fixed.deflate (fixed-Huffman + LZ77) for the python zlib(-15) check. */
public final class DeflateFixedMain {
    public static int32 run() {
        String text = "the quick brown fox jumps over the lazy dog. " +
            "the quick brown fox jumps over the lazy dog. " +
            "pack my box with five dozen liquor jugs.";
        int8[] in = text.bytes;
        int64 inLen = (int64) in.count();
        int8[] comp = Deflate.deflateFixed(in, inLen);
        int32 n = (int32) comp.count();
        FileWriter w = File.openWrite("/tmp/our_fixed.deflate", OpenMode.WRITE);
        w.write(comp, n);
        w.close();
        return 0;
    }
}
