{
    // cajeta-codec — standalone codec library (Part B of the codec framework).
    //
    // A LIBRARY project: no `entry-method`, so the build emits a reusable
    // `.cja` archive rather than an executable. Ships the specialized codec
    // formats that most programs never touch — `dev.cajeta.codec.{protobuf,
    // ion, avro, parquet, orc}`, the columnar tier, and the compression
    // codecs. These live under the `dev.cajeta.*` namespace (the convention for
    // our own non-stdlib libraries) — the core stdlib owns `cajeta.codec.*`
    // (json, csv, Base64) and a standalone `.cja` can't extend that namespace
    // through classpath linking. All our own code; no third-party libraries
    // (completeness by conformance corpus + fail-loud). See docs/ for the
    // framework spec and per-format specs. Core tier interfaces
    // (`cajeta.wire.*`) and the SIMD structural-scan pattern come from the
    // toolchain stdlib.

    "details": {
        "name":               "dev.cajeta.codec",
        "version":            "0.5.0",
        "description":        "cajeta-codec — standalone codec library (protobuf, ion, avro, parquet, orc)",
        "license":            "Apache-2.0",
        "authors":            ["Julian Klappenbach"],
        "cajeta-lang-version": "1.0"
    },

    "settings": {
        // Declare only what the library's public API actually needs;
        // capabilities are re-validated against the consumer's manifest at the
        // point of use. Codec formats are pure computation over byte buffers —
        // no ambient capability required for the in-memory parse/encode path.
        "capabilities": [],

        // Third-party runtime dependencies. The core stdlib (cajeta.lang,
        // cajeta.io, cajeta.codec.{json,csv}, cajeta.wire, …) is built into the
        // toolchain — neither declared nor fetched — and only the parts a
        // consumer uses are linked into its binary (dead-code elimination).
        "dependencies": {},

        // Test-only dependencies — not shipped in the published .cja.
        "dev-dependencies": {
            "cajeta.testkit": "1.0.*"
        },

        "repositories": [
            { "name": "central", "url": "https://repo.cajeta.org",
              "priority": 0 }
        ],

        // NO `entry-method` here — that is what makes this a library. With an
        // entry point the build emits an exe; without one it emits a .cja.
        "build": {
            "target": "host"
        }
    },

    "tasks": {

        "build": {
            "description": "Compile sources to a .cja library archive",
            "actions": [
                { "action": "build", "flavor": "debug", "id": "art" }
            ],
            "outputs": { "path": "${art.path}", "sha256": "${art.sha256}" }
        },

        "test": {
            "description": "Build + run the library's unit tests",
            "actions": [
                { "action": "build", "flavor": "debug", "profile": "test",
                  "id": "art" },
                { "action": "test", "params": { "input": "${art.path}" } }
            ]
        },

        "release": {
            "description": "Optimized release build of the library (.cja)",
            "actions": [
                { "action": "build", "flavor": "release", "id": "art" }
            ],
            "outputs": { "path": "${art.path}", "sha256": "${art.sha256}" }
        },

        "clean": {
            "description": "Wipe build outputs",
            "actions": [ { "action": "clean" } ]
        }
    }
}
