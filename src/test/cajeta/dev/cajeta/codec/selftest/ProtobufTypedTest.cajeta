package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.protobuf.Protobuf;
import dev.cajeta.codec.protobuf.ProtobufWriter;
import cajeta.lang.String;

/**
 * Phase 2.3 — typed decode (`Protobuf.parse<T>`). Encodes a message with
 * `ProtobufWriter`, decodes it back into `ProtoScalarMsg` via the synthesized
 * per-T bind, and checks every scalar field. The synthesizer walks the
 * `@ProtoField(N)` fields and emits a `ProtobufCursor`-driven bind.
 */
public class ProtobufTypedTest {

    public ProtobufTypedTest() {
        return;
    }

    @Test
    public void decodesScalarMessage() {
        ProtobufWriter w = heap ProtobufWriter();
        w.writeVarintField(1, (int64) 150);            // id
        String name = "hi";
        int8[] nb = name.bytes;
        w.writeLenField(2, nb, (int32) nb.count());    // name
        w.writeVarintField(3, (int64) 1);              // active = true
        w.writeVarintField(4, (int64) 42);             // count
        int8[] pay = {(int8) 0x07, (int8) 0x09};
        w.writeLenField(5, pay, (int32) 2);            // payload
        int8[] bytes = w.toBytes();

        ProtoScalarMsg m = Protobuf.parse<ProtoScalarMsg>(
            bytes, (int64) bytes.count());

        Assert.that(m.id).isEqualTo((int64) 150);
        Assert.isTrue(m.name.equals("hi"));
        Assert.isTrue(m.active);
        Assert.that((int64) m.count).isEqualTo((int64) 42);
        Assert.that((int64) m.payload.count()).isEqualTo((int64) 2);
        int8 p0 = m.payload[0];
        int8 p1 = m.payload[1];
        Assert.that((int64) (((int32) p0) & 0xFF)).isEqualTo((int64) 0x07);
        Assert.that((int64) (((int32) p1) & 0xFF)).isEqualTo((int64) 0x09);
        return;
    }

    @Test
    public void encodeDecodeScalarRoundTrips() {
        ProtoScalarMsg m = heap ProtoScalarMsg();
        m.id = (int64) 150;
        m.name = "hi";
        m.active = true;
        m.count = 42;
        int8[] pay = {(int8) 0x07, (int8) 0x09};
        m.payload = pay;

        int8[] bytes = Protobuf.toBytes<ProtoScalarMsg>(m);
        ProtoScalarMsg back = Protobuf.parse<ProtoScalarMsg>(
            bytes, (int64) bytes.count());

        Assert.that(back.id).isEqualTo((int64) 150);
        Assert.isTrue(back.name.equals("hi"));
        Assert.isTrue(back.active);
        Assert.that((int64) back.count).isEqualTo((int64) 42);
        Assert.that((int64) back.payload.count()).isEqualTo((int64) 2);
        int8 b0 = back.payload[0];
        Assert.that((int64) (((int32) b0) & 0xFF)).isEqualTo((int64) 0x07);
        return;
    }

    @Test
    public void encodeDecodeNestedRoundTrips() {
        ProtoInnerMsg inner = heap ProtoInnerMsg();
        inner.x = (int64) 77;
        inner.tag = "hi";
        ProtoOuterMsg outer = heap ProtoOuterMsg();
        outer.id = (int64) 5;
        outer.inner = inner;

        int8[] bytes = Protobuf.toBytes<ProtoOuterMsg>(outer);
        ProtoOuterMsg back = Protobuf.parse<ProtoOuterMsg>(
            bytes, (int64) bytes.count());

        Assert.that(back.id).isEqualTo((int64) 5);
        Assert.isTrue(back.inner != null);
        Assert.that(back.inner.x).isEqualTo((int64) 77);
        Assert.isTrue(back.inner.tag.equals("hi"));
        return;
    }

    @Test
    public void encodeDecodeStreamRoundTrips() {
        ProtoScalarMsg[] src = heap ProtoScalarMsg[2];
        ProtoScalarMsg a = heap ProtoScalarMsg();
        a.id = (int64) 11;
        a.count = 1;
        src[0] = a;
        ProtoScalarMsg b = heap ProtoScalarMsg();
        b.id = (int64) 22;
        b.count = 2;
        src[1] = b;

        int8[] bytes = Protobuf.toBytes<ProtoScalarMsg[]>(src);
        ProtoScalarMsg[] back = Protobuf.parse<ProtoScalarMsg[]>(
            bytes, (int64) bytes.count());

        Assert.that((int64) back.count()).isEqualTo((int64) 2);
        Assert.that(back[0].id).isEqualTo((int64) 11);
        Assert.that(back[1].id).isEqualTo((int64) 22);
        Assert.that((int64) back[1].count).isEqualTo((int64) 2);
        return;
    }

    @Test
    public void decodesNestedMessage() {
        // Encode the inner message, embed it as outer field 2 (LEN), and check
        // the synthesizer recurses (Protobuf.parse<ProtoInnerMsg> over the slice).
        ProtobufWriter iw = heap ProtobufWriter();
        iw.writeVarintField(1, (int64) 77);            // inner.x
        String tag = "hi";
        int8[] tb = tag.bytes;
        iw.writeLenField(2, tb, (int32) tb.count());   // inner.tag
        int8[] innerBytes = iw.toBytes();

        ProtobufWriter ow = heap ProtobufWriter();
        ow.writeVarintField(1, (int64) 5);             // outer.id
        ow.writeLenField(2, innerBytes, (int32) innerBytes.count());  // outer.inner
        int8[] bytes = ow.toBytes();

        ProtoOuterMsg m = Protobuf.parse<ProtoOuterMsg>(
            bytes, (int64) bytes.count());

        Assert.that(m.id).isEqualTo((int64) 5);
        Assert.isTrue(m.inner != null);
        Assert.that(m.inner.x).isEqualTo((int64) 77);
        Assert.isTrue(m.inner.tag.equals("hi"));
        return;
    }

    // Encode one ProtoScalarMsg with id=`id`, count=`count` and return its bytes.
    static #int8[] encodeScalar(int64 id, int64 count) {
        ProtobufWriter w = heap ProtobufWriter();
        w.writeVarintField(1, id);
        w.writeVarintField(4, count);
        return w.toBytes();
    }

    @Test
    public void decodesDelimitedStream() {
        // Three length-delimited messages → Protobuf.parse<ProtoScalarMsg[]>.
        ProtobufWriter s = heap ProtobufWriter();
        int8[] m0 = ProtobufTypedTest.encodeScalar((int64) 10, (int64) 1);
        s.writeDelimited(m0, (int32) m0.count());
        int8[] m1 = ProtobufTypedTest.encodeScalar((int64) 20, (int64) 2);
        s.writeDelimited(m1, (int32) m1.count());
        int8[] m2 = ProtobufTypedTest.encodeScalar((int64) 30, (int64) 3);
        s.writeDelimited(m2, (int32) m2.count());
        int8[] bytes = s.toBytes();

        ProtoScalarMsg[] msgs = Protobuf.parse<ProtoScalarMsg[]>(
            bytes, (int64) bytes.count());

        Assert.that((int64) msgs.count()).isEqualTo((int64) 3);
        Assert.that(msgs[0].id).isEqualTo((int64) 10);
        Assert.that(msgs[1].id).isEqualTo((int64) 20);
        Assert.that(msgs[2].id).isEqualTo((int64) 30);
        Assert.that((int64) msgs[0].count).isEqualTo((int64) 1);
        Assert.that((int64) msgs[2].count).isEqualTo((int64) 3);
        return;
    }

    @Test
    public void absentFieldsKeepConstructorDefaults() {
        // Only field 4 present — the rest stay at the ctor defaults (0 / false /
        // null), exercising slotOf == -1 skip in the synthesized bind.
        ProtobufWriter w = heap ProtobufWriter();
        w.writeVarintField(4, (int64) 99);
        int8[] bytes = w.toBytes();

        ProtoScalarMsg m = Protobuf.parse<ProtoScalarMsg>(
            bytes, (int64) bytes.count());

        Assert.that((int64) m.count).isEqualTo((int64) 99);
        Assert.that(m.id).isEqualTo((int64) 0);
        Assert.isFalse(m.active);
        return;
    }
}
