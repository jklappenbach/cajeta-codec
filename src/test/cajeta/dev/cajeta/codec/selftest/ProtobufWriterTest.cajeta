package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.protobuf.ProtobufWriter;
import dev.cajeta.codec.protobuf.ProtobufCursor;

/**
 * Phase 2.4 — ProtobufWriter wire encode + round-trip through ProtobufCursor.
 */
public class ProtobufWriterTest {

    public ProtobufWriterTest() {
        return;
    }

    // mask a signed int8 byte up to its unsigned value
    static int64 ub(int8 v) {
        return (int64) (((int32) v) & 0xFF);
    }

    @Test
    public void encodesVarint150ByteExact() {
        ProtobufWriter w = heap ProtobufWriter();
        w.writeVarint((int64) 150);
        int8[] b = w.toBytes();
        Assert.that((int64) b.count()).isEqualTo((int64) 2);
        int8 b0 = b[0];
        int8 b1 = b[1];
        Assert.that(ProtobufWriterTest.ub(b0)).isEqualTo((int64) 0x96);
        Assert.that(ProtobufWriterTest.ub(b1)).isEqualTo((int64) 0x01);
        return;
    }

    @Test
    public void roundTripsVarintAndLenThroughCursor() {
        ProtobufWriter w = heap ProtobufWriter();
        w.writeVarintField(1, (int64) 150);
        int8[] hi = {(int8) 0x68, (int8) 0x69};
        w.writeLenField(2, hi, (int32) 2);
        w.writeVarintField(3, (int64) 7);
        int8[] bytes = w.toBytes();

        ProtobufCursor cur = heap ProtobufCursor(bytes, (int64) bytes.count());
        int32 slot1 = cur.slotOf(1);
        int32 slot3 = cur.slotOf(3);
        int32 slot2 = cur.slotOf(2);
        Assert.that(cur.readVarint(slot1)).isEqualTo((int64) 150);
        Assert.that(cur.readVarint(slot3)).isEqualTo((int64) 7);
        int8[] back = cur.readBytes(slot2);
        Assert.that((int64) back.count()).isEqualTo((int64) 2);
        int8 h0 = back[0];
        int8 h1 = back[1];
        Assert.that(ProtobufWriterTest.ub(h0)).isEqualTo((int64) 0x68);
        Assert.that(ProtobufWriterTest.ub(h1)).isEqualTo((int64) 0x69);
        return;
    }

    @Test
    public void roundTripsFixedThroughCursor() {
        ProtobufWriter w = heap ProtobufWriter();
        w.writeFixed32Field(5, (int32) 0x04030201);
        w.writeFixed64Field(6, (int64) 0x0807060504030201);
        int8[] bytes = w.toBytes();

        ProtobufCursor cur = heap ProtobufCursor(bytes, (int64) bytes.count());
        Assert.that((int64) cur.readFixed32(cur.slotOf(5)))
            .isEqualTo((int64) 0x04030201);
        Assert.that(cur.readFixed64(cur.slotOf(6)))
            .isEqualTo((int64) 0x0807060504030201);
        return;
    }

    @Test
    public void growsBufferAndRoundTripsManyFields() {
        // Far more than the initial 64-byte capacity → exercises ensure()/grow.
        ProtobufWriter w = heap ProtobufWriter();
        int32 i = 0;
        while (i < 100) {
            w.writeVarintField(1, (int64) i);
            i = i + 1;
        }
        int8[] bytes = w.toBytes();
        ProtobufCursor cur = heap ProtobufCursor(bytes, (int64) bytes.count());
        Assert.that((int64) cur.fieldCount()).isEqualTo((int64) 100);
        // first and last field-1 occurrences decode to 0 and 99
        Assert.that(cur.readVarint(0)).isEqualTo((int64) 0);
        Assert.that(cur.readVarint(99)).isEqualTo((int64) 99);
        return;
    }
}
