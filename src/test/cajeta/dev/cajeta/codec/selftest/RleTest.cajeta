package dev.cajeta.codec.selftest;

import org.cajeta.unit.Assert;
import dev.cajeta.codec.columnar.Rle;

/**
 * Phase 6.1b — Parquet RLE/bit-packing hybrid decode. Fixtures (python, spec
 * encoder) mix an RLE run with a bit-packed group: w=3 (`4×5` then `0..7`),
 * w=1 boolean-style, and a w=0 all-zeros RLE run (no value bytes).
 */
public class RleTest {

    public RleTest() {
        return;
    }

    @Test
    public void decodesRleThenBitPackedW3() {
        int8[] s = { (int8) 0x0B, (int8) 0x04, (int8) 0x02,
                     (int8) 0x88, (int8) 0xC6, (int8) 0xFA };
        int32[] got = Rle.decode(s, (int64) 0, 3, 13);
        int32[] want = { 4, 4, 4, 4, 4, 0, 1, 2, 3, 4, 5, 6, 7 };
        int32 i = 0;
        while (i < 13) {
            Assert.that((int64) got[i]).isEqualTo((int64) want[i]);
            i = i + 1;
        }
        return;
    }

    @Test
    public void decodesBooleanW1() {
        int8[] s2 = { (int8) 0x07, (int8) 0x01, (int8) 0x02, (int8) 0x4D };
        int32[] got = Rle.decode(s2, (int64) 0, 1, 11);
        int32[] want = { 1, 1, 1, 1, 0, 1, 1, 0, 0, 1, 0 };
        int32 i = 0;
        while (i < 11) {
            Assert.that((int64) got[i]).isEqualTo((int64) want[i]);
            i = i + 1;
        }
        return;
    }

    @Test
    public void decodesWidthZeroRun() {
        int8[] s3 = { (int8) 0x0D };
        int32[] got = Rle.decode(s3, (int64) 0, 0, 6);
        int32 i = 0;
        while (i < 6) {
            Assert.that((int64) got[i]).isEqualTo((int64) 0);
            i = i + 1;
        }
        return;
    }
}
