package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.orc.OrcRleV2;

/**
 * Phase 8.1b/8.3 — ORC integer RLE v2 decode. Hand-encoded (spec) vectors for
 * SHORT_REPEAT, DIRECT, and DELTA (fixed + bit-packed). Validated by the decoded
 * sum (returning int64[] to the test exe miscompiles); each vector was
 * cross-checked against a python reference decoder.
 */
public class OrcRleV2Test {

    public OrcRleV2Test() {
        return;
    }

    @Test
    public void shortRepeat() {
        // [7,7,7,7,7]
        int8[] b = { (int8) 0x02, (int8) 0x0E };
        Assert.that(OrcRleV2.decodeSum(b, (int64) 0, 5)).isEqualTo((int64) 35);
        return;
    }

    @Test
    public void deltaFixed() {
        // [5,10,15,20]
        int8[] b = { (int8) 0xC0, (int8) 0x03, (int8) 0x0A, (int8) 0x0A };
        Assert.that(OrcRleV2.decodeSum(b, (int64) 0, 4)).isEqualTo((int64) 50);
        return;
    }

    @Test
    public void deltaBitPacked() {
        // [1,2,4,7]
        int8[] b = { (int8) 0xC2, (int8) 0x03, (int8) 0x02, (int8) 0x02, (int8) 0xB0 };
        Assert.that(OrcRleV2.decodeSum(b, (int64) 0, 4)).isEqualTo((int64) 14);
        return;
    }

    @Test
    public void direct() {
        // [1,3,5]
        int8[] b = { (int8) 0x46, (int8) 0x02, (int8) 0x26, (int8) 0xA0 };
        Assert.that(OrcRleV2.decodeSum(b, (int64) 0, 3)).isEqualTo((int64) 9);
        return;
    }

    @Test
    public void patchedBase() {
        // REAL pyarrow ORC DATA stream: 100 int64s, 90 small + 10 outliers,
        // encoded PATCHED_BASE (W=23, base 1B, PW=1, PGW=7, 2 patches). Sum
        // verified bit-exact vs pyarrow's read_table (62973511).
        int8[] b = {
            (int8) 0xAC, (int8) 0x63, (int8) 0x00, (int8) 0xC2, (int8) 0x00, (int8) 0x00, (int8) 0x00, (int8) 0x4C, (int8) 0x00, (int8) 0x00, (int8) 0x7C, (int8) 0x00,
            (int8) 0x01, (int8) 0x28, (int8) 0x00, (int8) 0x03, (int8) 0x30, (int8) 0x00, (int8) 0x03, (int8) 0xA0, (int8) 0x00, (int8) 0x01, (int8) 0x00, (int8) 0x00,
            (int8) 0x1A, (int8) 0x80, (int8) 0x00, (int8) 0x05, (int8) 0x00, (int8) 0x00, (int8) 0x78, (int8) 0x00, (int8) 0x00, (int8) 0x44, (int8) 0x00, (int8) 0x00,
            (int8) 0xF0, (int8) 0x00, (int8) 0x02, (int8) 0xC0, (int8) 0x00, (int8) 0x05, (int8) 0x40, (int8) 0x00, (int8) 0x01, (int8) 0x00, (int8) 0x00, (int8) 0x01,
            (int8) 0x80, (int8) 0x00, (int8) 0x2E, (int8) 0x00, (int8) 0x00, (int8) 0x58, (int8) 0x00, (int8) 0x00, (int8) 0x4C, (int8) 0x00, (int8) 0x01, (int8) 0x48,
            (int8) 0x00, (int8) 0x02, (int8) 0x40, (int8) 0x00, (int8) 0x05, (int8) 0x60, (int8) 0x00, (int8) 0x0D, (int8) 0x00, (int8) 0x00, (int8) 0x0E, (int8) 0x00,
            (int8) 0x00, (int8) 0x12, (int8) 0x00, (int8) 0x00, (int8) 0x5A, (int8) 0x00, (int8) 0x00, (int8) 0x60, (int8) 0x00, (int8) 0x01, (int8) 0xC0, (int8) 0x00,
            (int8) 0x02, (int8) 0xA0, (int8) 0x00, (int8) 0x02, (int8) 0xC0, (int8) 0x00, (int8) 0x00, (int8) 0x40, (int8) 0x00, (int8) 0x1E, (int8) 0x00, (int8) 0x00,
            (int8) 0x1D, (int8) 0x00, (int8) 0x00, (int8) 0x2C, (int8) 0x00, (int8) 0x00, (int8) 0x28, (int8) 0x00, (int8) 0x01, (int8) 0x38, (int8) 0x00, (int8) 0x00,
            (int8) 0x70, (int8) 0x00, (int8) 0x03, (int8) 0xE0, (int8) 0x00, (int8) 0x00, (int8) 0xC0, (int8) 0x00, (int8) 0x06, (int8) 0x80, (int8) 0x00, (int8) 0x31,
            (int8) 0x00, (int8) 0x00, (int8) 0x24, (int8) 0x00, (int8) 0x00, (int8) 0x20, (int8) 0x00, (int8) 0x01, (int8) 0x78, (int8) 0x00, (int8) 0x00, (int8) 0xF0,
            (int8) 0x00, (int8) 0x03, (int8) 0x20, (int8) 0x00, (int8) 0x06, (int8) 0x40, (int8) 0x00, (int8) 0x1D, (int8) 0x00, (int8) 0x00, (int8) 0x37, (int8) 0x00,
            (int8) 0x00, (int8) 0x3E, (int8) 0x00, (int8) 0x00, (int8) 0x14, (int8) 0x00, (int8) 0x00, (int8) 0x50, (int8) 0x00, (int8) 0x01, (int8) 0xC0, (int8) 0x00,
            (int8) 0x03, (int8) 0x20, (int8) 0x00, (int8) 0x08, (int8) 0xC0, (int8) 0x00, (int8) 0x08, (int8) 0x80, (int8) 0x00, (int8) 0x38, (int8) 0x00, (int8) 0x00,
