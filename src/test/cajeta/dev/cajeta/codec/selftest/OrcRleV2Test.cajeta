            (int8) 0x60, (int8) 0x00, (int8) 0x04, (int8) 0x40, (int8) 0x00, (int8) 0x16, (int8) 0x80, (int8) 0x00, (int8) 0x1A, (int8) 0x00, (int8) 0x00, (int8) 0x2C,
            (int8) 0x00, (int8) 0x00, (int8) 0xAC, (int8) 0x00, (int8) 0x01, (int8) 0xC0, (int8) 0x00, (int8) 0x01, (int8) 0x80, (int8) 0x00, (int8) 0x01, (int8) 0xC0,
            (int8) 0x00, (int8) 0x02, (int8) 0x40, (int8) 0x00, (int8) 0x02, (int8) 0x80, (int8) 0x00, (int8) 0x0B, (int8) 0x00, (int8) 0x00, (int8) 0x12, (int8) 0x00,
            (int8) 0x00, (int8) 0x38, (int8) 0x00, (int8) 0x01, (int8) 0x50, (int8) 0x00, (int8) 0x00, (int8) 0xE0, (int8) 0x00, (int8) 0x00, (int8) 0x00, (int8) 0x00,
            (int8) 0x07, (int8) 0xC0, (int8) 0x00, (int8) 0x1A, (int8) 0x80, (int8) 0x00, (int8) 0x25, (int8) 0x00, (int8) 0x00, (int8) 0x16, (int8) 0x00, (int8) 0x00,
            (int8) 0x40, (int8) 0x00, (int8) 0x00, (int8) 0x90, (int8) 0x00, (int8) 0x00, (int8) 0x00, (int8) 0x00, (int8) 0x01, (int8) 0x20, (int8) 0x00, (int8) 0x06,
            (int8) 0x80, (int8) 0x00, (int8) 0x11, (int8) 0x00, (int8) 0x00, (int8) 0x17, (int8) 0x00, (int8) 0x00, (int8) 0x4E, (int8) 0x00, (int8) 0x00, (int8) 0x93,
            (int8) 0x06, (int8) 0x96, (int8) 0x42, (int8) 0xF6, (int8) 0x27, (int8) 0x62, (int8) 0x67, (int8) 0x2F, (int8) 0xE7, (int8) 0x45, (int8) 0x2E, (int8) 0x82,
            (int8) 0x14, (int8) 0x6D, (int8) 0x73, (int8) 0xB5, (int8) 0x31, (int8) 0xEA, (int8) 0x54, (int8) 0x49, (int8) 0xD5, (int8) 0x96, (int8) 0xEB, (int8) 0xA1,
            (int8) 0x3A, (int8) 0x62, (int8) 0x9C, (int8) 0x3A, (int8) 0x80, (int8) 0xB9, (int8) 0x05
        };
        Assert.that(OrcRleV2.decodeSum(b, (int64) 0, 100)).isEqualTo((int64) 62973511);
        return;
    }

    @Test
    public void encodeDirectRoundTrips() {
        int64[] v = heap int64[4];
        v[0] = (int64) 5; v[1] = (int64) 10; v[2] = (int64) 15; v[3] = (int64) 20;
        int8[] enc = OrcRleV2.encodeDirect(v, 4);
        Assert.that(OrcRleV2.decodeSum(enc, (int64) 0, 4)).isEqualTo((int64) 50);
        return;
    }

    @Test
    public void encodeDirectWideAndNegative() {
        // mixed widths + a negative → exercises zigzag + width selection.
        int64[] v = heap int64[5];
        v[0] = (int64) 1000; v[1] = (int64) 0 - (int64) 2000; v[2] = (int64) 3;
        v[3] = (int64) 0; v[4] = (int64) 65000;
        int8[] enc = OrcRleV2.encodeDirect(v, 5);
        Assert.that(OrcRleV2.decodeSum(enc, (int64) 0, 5)).isEqualTo((int64) 64003);
        return;
    }
}
