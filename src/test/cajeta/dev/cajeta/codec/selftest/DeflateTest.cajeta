package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.compress.Deflate;
import cajeta.lang.String;

/**
 * Phase 4.2a — DEFLATE inflation, against golden raw-deflate blobs produced by
 * python `zlib` (wbits=-15), covering a stored block, a short match, and a
 * dynamic-Huffman block.
 */
public class DeflateTest {

    public DeflateTest() {
        return;
    }

    @Test
    public void inflatesStoredBlock() {
        // zlib level 0, "hello world".
        int8[] blob = {
            (int8) 0x01, (int8) 0x0B, (int8) 0x00, (int8) 0xF4, (int8) 0xFF,
            (int8) 0x68, (int8) 0x65, (int8) 0x6C, (int8) 0x6C, (int8) 0x6F,
            (int8) 0x20, (int8) 0x77, (int8) 0x6F, (int8) 0x72, (int8) 0x6C,
            (int8) 0x64
        };
        int8[] out = Deflate.inflate(blob, (int64) blob.count(), (int64) 11);
        String s = heap cajeta.lang.String(#out, (int32) out.count());
        Assert.isTrue(s.equals("hello world"));
        return;
    }

    @Test
    public void inflatesShortMatch() {
        // zlib default, "abcabcabcabcabcabc" (18 bytes).
        int8[] blob = {
            (int8) 0x4B, (int8) 0x4C, (int8) 0x4A, (int8) 0x4E, (int8) 0x44,
            (int8) 0x45, (int8) 0x00
        };
        int8[] out = Deflate.inflate(blob, (int64) blob.count(), (int64) 18);
        String s = heap cajeta.lang.String(#out, (int32) out.count());
        Assert.isTrue(s.equals("abcabcabcabcabcabc"));
        return;
    }

    @Test
    public void deflateInflateRoundTrips() {
        String text = "the quick brown fox jumps over the lazy dog";
        int8[] in = text.toBytes();
        int64 inLen = (int64) in.count();
        int8[] comp = Deflate.deflate(in, inLen);
        int8[] out = Deflate.inflate(comp, (int64) comp.count(), inLen);
        String back = heap cajeta.lang.String(#out, (int32) out.count());
        Assert.isTrue(back.equals("the quick brown fox jumps over the lazy dog"));
        return;
    }

    @Test
    public void deflateFixedRoundTrips() {
        // 4.3a — fixed-Huffman literal block, round-tripped through our decoder.
        String text = "the quick brown fox jumps over the lazy dog";
        int8[] in = text.toBytes();
        int64 inLen = (int64) in.count();
        int8[] comp = Deflate.deflateFixed(in, inLen);
        int8[] out = Deflate.inflate(comp, (int64) comp.count(), inLen);
        String back = heap cajeta.lang.String(#out, (int32) out.count());
        Assert.isTrue(back.equals("the quick brown fox jumps over the lazy dog"));
        return;
    }

    @Test
    public void deflateFixedHighBytesRoundTrip() {
        // 4.3a — exercise the 9-bit literal codes (bytes >= 144).
        int8[] in = heap int8[64];
        int32 i = 0;
        while (i < 64) { in[i] = (int8) (140 + i); i = i + 1; }
        int64 inLen = (int64) 64;
        int8[] comp = Deflate.deflateFixed(in, inLen);
        int8[] out = Deflate.inflate(comp, (int64) comp.count(), inLen);
        boolean ok = true;
        int32 k = 0;
        while (k < 64) {
            int32 a = ((int32) out[k]) & 0xFF;
            int32 b = (140 + k) & 0xFF;
            if (a != b) { ok = false; }
            k = k + 1;
        }
        Assert.isTrue(ok);
        return;
    }

    @Test
    public void deflateFixedCompressesRepetitive() {
        // 4.3b — a period-8 pattern is almost all back-references; must shrink
        // far below the ~205-byte stored size, and round-trip exactly.
        int8[] in = heap int8[200];
        int32 i = 0;
        while (i < 200) { in[i] = (int8) (65 + (i % 8)); i = i + 1; }
        int64 inLen = (int64) 200;
        int8[] comp = Deflate.deflateFixed(in, inLen);
        int64 compLen = (int64) comp.count();   // capture before the move into inflate
        int8[] out = Deflate.inflate(comp, compLen, inLen);
        boolean ok = true;
        int32 k = 0;
        while (k < 200) {
            int32 a = ((int32) out[k]) & 0xFF;
            int32 b = (65 + (k % 8)) & 0xFF;
            if (a != b) { ok = false; }
            k = k + 1;
        }
        Assert.isTrue(ok);
        Assert.that(compLen).isLessThan((int64) 60);
        return;
    }

    @Test
    public void deflateFixedTextRoundTripWithMatches() {
        // 4.3b — repeated phrases produce matches; round-trips and shrinks.
        String text = "the quick brown fox. the quick brown fox. " +
            "the quick brown fox. the quick brown fox.";
        int8[] in = text.toBytes();
        int64 inLen = (int64) in.count();
        int8[] comp = Deflate.deflateFixed(in, inLen);
        int64 compLen = (int64) comp.count();   // capture before the move into inflate
        int8[] out = Deflate.inflate(comp, compLen, inLen);
        String back = heap cajeta.lang.String(#out, (int32) out.count());
        Assert.isTrue(back.equals(
            "the quick brown fox. the quick brown fox. " +
            "the quick brown fox. the quick brown fox."));
        Assert.that(compLen).isLessThan(inLen);
        return;
    }

    @Test
    public void deflateFixedLongRunRoundTrip() {
        // 4.3b — a single repeated byte exercises max-length (258) matches +
        // overlapping copies in the decoder.
        int8[] in = heap int8[1000];
        int32 i = 0;
        while (i < 1000) { in[i] = (int8) 0x5A; i = i + 1; }
        int64 inLen = (int64) 1000;
        int8[] comp = Deflate.deflateFixed(in, inLen);
        int64 compLen = (int64) comp.count();   // capture before the move into inflate
        int8[] out = Deflate.inflate(comp, compLen, inLen);
        boolean ok = true;
        int32 k = 0;
        while (k < 1000) {
            int32 a = ((int32) out[k]) & 0xFF;
            if (a != 0x5A) { ok = false; }
            k = k + 1;
        }
        Assert.isTrue(ok);
        Assert.that(compLen).isLessThan((int64) 40);
        return;
    }

    @Test
    public void inflatesDynamicHuffman() {
        // zlib level 9, "the quick brown fox jumps over the lazy dog. " x4 (180).
        int8[] blob = {
            (int8) 0x2B, (int8) 0xC9, (int8) 0x48, (int8) 0x55, (int8) 0x28,
            (int8) 0x2C, (int8) 0xCD, (int8) 0x4C, (int8) 0xCE, (int8) 0x56,
            (int8) 0x48, (int8) 0x2A, (int8) 0xCA, (int8) 0x2F, (int8) 0xCF,
            (int8) 0x53, (int8) 0x48, (int8) 0xCB, (int8) 0xAF, (int8) 0x50,
            (int8) 0xC8, (int8) 0x2A, (int8) 0xCD, (int8) 0x2D, (int8) 0x28,
            (int8) 0x56, (int8) 0xC8, (int8) 0x2F, (int8) 0x4B, (int8) 0x2D,
            (int8) 0x52, (int8) 0x28, (int8) 0x01, (int8) 0x4A, (int8) 0xE7,
            (int8) 0x24, (int8) 0x56, (int8) 0x55, (int8) 0x2A, (int8) 0xA4,
            (int8) 0xE4, (int8) 0xA7, (int8) 0xEB, (int8) 0x81, (int8) 0x79,
            (int8) 0x83, (int8) 0x40, (int8) 0x31, (int8) 0x00
        };
        int8[] out = Deflate.inflate(blob, (int64) blob.count(), (int64) 180);
        String s = heap cajeta.lang.String(#out, (int32) out.count());
        Assert.isTrue(s.equals(
            "the quick brown fox jumps over the lazy dog. " +
            "the quick brown fox jumps over the lazy dog. " +
            "the quick brown fox jumps over the lazy dog. " +
            "the quick brown fox jumps over the lazy dog. "));
        return;
    }
}
