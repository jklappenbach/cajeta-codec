package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.avro.AvroCursor;
import cajeta.lang.String;

/**
 * Phase 5.1a — Avro binary primitives via `AvroCursor`. Hand-encoded spec
 * vectors exercise zigzag-varint longs (incl. negatives and a two-byte varint),
 * boolean, and a length-prefixed string, read sequentially.
 */
public class AvroCursorTest {

    public AvroCursorTest() {
        return;
    }

    @Test
    public void readsZigzagLongs() {
        // zigzag: 0x00→0, 0x01→-1, 0x02→1, 0x03→-2, 0x04→2, [0x80,0x01]→64.
        int8[] b = {
            (int8) 0x00, (int8) 0x01, (int8) 0x02, (int8) 0x03, (int8) 0x04,
            (int8) 0x80, (int8) 0x01
        };
        AvroCursor c = heap AvroCursor(b, (int64) 0);
        Assert.that(c.readLong()).isEqualTo((int64) 0);
        Assert.that(c.readLong()).isEqualTo((int64) 0 - (int64) 1);
        Assert.that(c.readLong()).isEqualTo((int64) 1);
        Assert.that(c.readLong()).isEqualTo((int64) 0 - (int64) 2);
        Assert.that(c.readLong()).isEqualTo((int64) 2);
        Assert.that(c.readLong()).isEqualTo((int64) 64);
        Assert.that(c.position()).isEqualTo((int64) 7);
        return;
    }

    @Test
    public void readsBooleanAndString() {
        // true (0x01), then string "hi": long len 2 (zigzag 4 → 0x04) + 'h','i'.
        int8[] b = {
            (int8) 0x01,
            (int8) 0x04, (int8) 0x68, (int8) 0x69
        };
        AvroCursor c = heap AvroCursor(b, (int64) 0);
        Assert.isTrue(c.readBoolean());
        Assert.isTrue(c.readString().equals("hi"));
        Assert.that(c.position()).isEqualTo((int64) 4);
        return;
    }

    @Test
    public void readsBytes() {
        // bytes [0x07,0x09]: long len 2 (0x04) + the two bytes.
        int8[] b = { (int8) 0x04, (int8) 0x07, (int8) 0x09 };
        AvroCursor c = heap AvroCursor(b, (int64) 0);
        int8[] out = c.readBytes();
        Assert.that((int64) out.count()).isEqualTo((int64) 2);
        int8 p0 = out[0];
        int8 p1 = out[1];
        Assert.that((int64) (((int32) p0) & 0xFF)).isEqualTo((int64) 0x07);
        Assert.that((int64) (((int32) p1) & 0xFF)).isEqualTo((int64) 0x09);
        return;
    }
}
