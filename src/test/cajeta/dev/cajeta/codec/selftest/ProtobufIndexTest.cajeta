package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.protobuf.ProtobufIndex;
import dev.cajeta.codec.protobuf.ProtobufWire;

/**
 * Phase 2.1b — ProtobufIndex structural scan. Hand-encoded protobuf messages;
 * asserts per-field number/wire-type/value-bounds and fail-loud on group /
 * unknown wire types.
 */
public class ProtobufIndexTest {

    public ProtobufIndexTest() {
        return;
    }

    @Test
    public void indexesSingleVarintField() {
        // field 1, VARINT, value 150 → tag 0x08, varint 0x96 0x01
        int8[] b = {(int8) 0x08, (int8) 0x96, (int8) 0x01};
        ProtobufIndex idx = ProtobufIndex.build(b, (int64) 3);
        Assert.that((int64) idx.fieldCount()).isEqualTo((int64) 1);
        Assert.that((int64) idx.fieldNumber(0)).isEqualTo((int64) 1);
        Assert.that((int64) idx.wireType(0)).isEqualTo((int64) 0);
        Assert.that(idx.valueStart(0)).isEqualTo((int64) 1);
        Assert.that(idx.valueEnd(0)).isEqualTo((int64) 3);
        // the value is reachable at valueStart
        Assert.that(ProtobufWire.decodeVarint(b, idx.valueStart(0)))
            .isEqualTo((int64) 150);
        return;
    }

    @Test
    public void indexesLenField() {
        // field 2, LEN "hi" → tag 0x12, len 0x02, 'h' 'i'
        int8[] b = {(int8) 0x12, (int8) 0x02, (int8) 0x68, (int8) 0x69};
        ProtobufIndex idx = ProtobufIndex.build(b, (int64) 4);
        Assert.that((int64) idx.fieldCount()).isEqualTo((int64) 1);
        Assert.that((int64) idx.fieldNumber(0)).isEqualTo((int64) 2);
        Assert.that((int64) idx.wireType(0)).isEqualTo((int64) 2);
        // value = the payload AFTER the length prefix: bytes [2,4)
        Assert.that(idx.valueStart(0)).isEqualTo((int64) 2);
        Assert.that(idx.valueEnd(0)).isEqualTo((int64) 4);
        return;
    }

    @Test
    public void indexesTwoFields() {
        // field 1 VARINT 150, then field 2 LEN "hi"
        int8[] b = {(int8) 0x08, (int8) 0x96, (int8) 0x01,
                    (int8) 0x12, (int8) 0x02, (int8) 0x68, (int8) 0x69};
        ProtobufIndex idx = ProtobufIndex.build(b, (int64) 7);
        Assert.that((int64) idx.fieldCount()).isEqualTo((int64) 2);
        Assert.that((int64) idx.fieldNumber(1)).isEqualTo((int64) 2);
        Assert.that((int64) idx.wireType(1)).isEqualTo((int64) 2);
        Assert.that(idx.valueStart(1)).isEqualTo((int64) 5);
        Assert.that(idx.valueEnd(1)).isEqualTo((int64) 7);
        return;
    }

    @Test
    public void indexesFixed32And64() {
        // field 5 I32 (tag 0x2D, 4 bytes), then field 6 I64 (tag 0x31, 8 bytes)
        int8[] b = {(int8) 0x2D, (int8) 1, (int8) 2, (int8) 3, (int8) 4,
                    (int8) 0x31, (int8) 1, (int8) 2, (int8) 3, (int8) 4,
                    (int8) 5, (int8) 6, (int8) 7, (int8) 8};
        ProtobufIndex idx = ProtobufIndex.build(b, (int64) 14);
        Assert.that((int64) idx.fieldCount()).isEqualTo((int64) 2);
        Assert.that((int64) idx.wireType(0)).isEqualTo((int64) 5);   // I32
        Assert.that(idx.valueEnd(0) - idx.valueStart(0)).isEqualTo((int64) 4);
        Assert.that((int64) idx.wireType(1)).isEqualTo((int64) 1);   // I64
        Assert.that(idx.valueEnd(1) - idx.valueStart(1)).isEqualTo((int64) 8);
        return;
    }

    @Test
    public void groupWireTypeFailsLoud() {
        // field 1, wire type 3 (group start, deprecated) → tag 0x0B
        int8[] b = {(int8) 0x0B};
        Assert.assertThrows(() -> {
            ProtobufIndex.build(b, (int64) 1);
        });
        return;
    }

    @Test
    public void unknownWireTypeFailsLoud() {
        // wire type 6 (unknown) → tag (1<<3)|6 = 14 = 0x0E
        int8[] b = {(int8) 0x0E};
        Assert.assertThrows(() -> {
            ProtobufIndex.build(b, (int64) 1);
        });
        return;
    }
}
