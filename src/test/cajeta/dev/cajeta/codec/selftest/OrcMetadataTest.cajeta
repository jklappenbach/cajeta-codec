package dev.cajeta.codec.selftest;

import org.cajeta.unit.Assert;
import dev.cajeta.codec.orc.OrcMetadata;

/**
 * Phase 8.1a — ORC PostScript + Footer (protobuf) metadata against a REAL pyarrow
 * ORC file (`x` = [5,10,15,20], 4 rows, uncompressed). Reuses the Phase-2 protobuf
 * decoder to walk the protobuf footer.
 */
public class OrcMetadataTest {

    public OrcMetadataTest() {
        return;
    }

    static #int8[] simpleOrc() {
        int8[] b = {
            (int8) 0x4F, (int8) 0x52, (int8) 0x43, (int8) 0x0A, (int8) 0x06, (int8) 0x12, (int8) 0x04, (int8) 0x08, (int8) 0x04, (int8) 0x50, (int8) 0x00, (int8) 0x0A,
            (int8) 0x12, (int8) 0x0A, (int8) 0x02, (int8) 0x00, (int8) 0x00, (int8) 0x12, (int8) 0x0C, (int8) 0x08, (int8) 0x04, (int8) 0x12, (int8) 0x06, (int8) 0x08,
            (int8) 0x0A, (int8) 0x10, (int8) 0x28, (int8) 0x18, (int8) 0x64, (int8) 0x50, (int8) 0x00, (int8) 0xC0, (int8) 0x03, (int8) 0x0A, (int8) 0x0A, (int8) 0x0A,
            (int8) 0x06, (int8) 0x08, (int8) 0x06, (int8) 0x10, (int8) 0x00, (int8) 0x18, (int8) 0x08, (int8) 0x0A, (int8) 0x06, (int8) 0x08, (int8) 0x06, (int8) 0x10,
            (int8) 0x01, (int8) 0x18, (int8) 0x14, (int8) 0x0A, (int8) 0x06, (int8) 0x08, (int8) 0x01, (int8) 0x10, (int8) 0x01, (int8) 0x18, (int8) 0x04, (int8) 0x12,
            (int8) 0x04, (int8) 0x08, (int8) 0x00, (int8) 0x10, (int8) 0x00, (int8) 0x12, (int8) 0x04, (int8) 0x08, (int8) 0x02, (int8) 0x10, (int8) 0x00, (int8) 0x1A,
            (int8) 0x03, (int8) 0x47, (int8) 0x4D, (int8) 0x54, (int8) 0x0A, (int8) 0x14, (int8) 0x0A, (int8) 0x04, (int8) 0x08, (int8) 0x04, (int8) 0x50, (int8) 0x00,
            (int8) 0x0A, (int8) 0x0C, (int8) 0x08, (int8) 0x04, (int8) 0x12, (int8) 0x06, (int8) 0x08, (int8) 0x0A, (int8) 0x10, (int8) 0x28, (int8) 0x18, (int8) 0x64,
            (int8) 0x50, (int8) 0x00, (int8) 0x08, (int8) 0x03, (int8) 0x10, (int8) 0x49, (int8) 0x1A, (int8) 0x0A, (int8) 0x08, (int8) 0x03, (int8) 0x10, (int8) 0x1C,
            (int8) 0x18, (int8) 0x04, (int8) 0x20, (int8) 0x29, (int8) 0x28, (int8) 0x04, (int8) 0x22, (int8) 0x0E, (int8) 0x08, (int8) 0x0C, (int8) 0x12, (int8) 0x01,
            (int8) 0x01, (int8) 0x1A, (int8) 0x01, (int8) 0x78, (int8) 0x20, (int8) 0x00, (int8) 0x28, (int8) 0x00, (int8) 0x30, (int8) 0x00, (int8) 0x22, (int8) 0x08,
            (int8) 0x08, (int8) 0x03, (int8) 0x20, (int8) 0x00, (int8) 0x28, (int8) 0x00, (int8) 0x30, (int8) 0x00, (int8) 0x30, (int8) 0x04, (int8) 0x3A, (int8) 0x04,
            (int8) 0x08, (int8) 0x04, (int8) 0x50, (int8) 0x00, (int8) 0x3A, (int8) 0x0C, (int8) 0x08, (int8) 0x04, (int8) 0x12, (int8) 0x06, (int8) 0x08, (int8) 0x0A,
            (int8) 0x10, (int8) 0x28, (int8) 0x18, (int8) 0x64, (int8) 0x50, (int8) 0x00, (int8) 0x40, (int8) 0x90, (int8) 0x4E, (int8) 0x48, (int8) 0x01, (int8) 0x62,
            (int8) 0x05, (int8) 0x32, (int8) 0x2E, (int8) 0x32, (int8) 0x2E, (int8) 0x32, (int8) 0x08, (int8) 0x4C, (int8) 0x10, (int8) 0x00, (int8) 0x18, (int8) 0x80,
            (int8) 0x80, (int8) 0x04, (int8) 0x22, (int8) 0x02, (int8) 0x00, (int8) 0x0C, (int8) 0x28, (int8) 0x16, (int8) 0x30, (int8) 0x06, (int8) 0x82, (int8) 0xF4,
            (int8) 0x03, (int8) 0x03, (int8) 0x4F, (int8) 0x52, (int8) 0x43, (int8) 0x17
        };        return b;
    }

    @Test
    public void parsesPostscriptAndFooter() {
        int8[] f = OrcMetadataTest.simpleOrc();
        OrcMetadata m = OrcMetadata.parse(f, (int64) f.count());
        Assert.that(m.footerLength).isEqualTo((int64) 76);
        Assert.that((int64) m.compression).isEqualTo((int64) 0);   // NONE
        Assert.that(m.numberOfRows).isEqualTo((int64) 4);
        Assert.that((int64) m.stripeCount).isEqualTo((int64) 1);
        Assert.that((int64) m.typeCount).isEqualTo((int64) 2);     // root + x
        return;
    }
}
