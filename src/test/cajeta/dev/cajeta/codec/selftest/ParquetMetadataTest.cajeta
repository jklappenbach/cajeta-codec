package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.parquet.ParquetMetadata;
import dev.cajeta.codec.parquet.ParquetColumnInfo;

/**
 * Phase 7.1b — Parquet footer + FileMetaData decode against a REAL pyarrow-written
 * file (single INT32 column `x` = [1..5], PLAIN, uncompressed). Asserts the
 * decoded metadata matches pyarrow's reported values.
 */
