package dev.cajeta.codec.selftest;

import dev.cajeta.unit.Assert;
import dev.cajeta.codec.orc.OrcMetadata;
import dev.cajeta.codec.orc.OrcColumnReader;

/**
 * Phase 8.3a — ORC **compressed** stream decode against a REAL pyarrow ORC file
 * written with `compression='zlib'` (`x` = [5,10,15,20,25,30,35,40], sum 180).
 * The PostScript is always raw; the Footer, StripeFooter, and DATA streams are
 * each chunked (3-byte LE header `(len<<1)|isOriginal`) with raw-DEFLATE chunks,
 * decompressed via the Phase-4 `Deflate.inflateGrow`. Validates that metadata +
 * single-column read flow through the decompression layer.
 */
public class OrcCompressedTest {

    public OrcCompressedTest() {
        return;
    }

    static #int8[] zlibOrc() {
        int8[] b = {
            (int8) 0x4F, (int8) 0x52, (int8) 0x43, (int8) 0x11, (int8) 0x00, (int8) 0x00, (int8) 0x0A, (int8) 0x06, (int8) 0x12, (int8) 0x04, (int8) 0x08, (int8) 0x08,
