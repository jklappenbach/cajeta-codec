            (int8) 0x80, (int8) 0x80, (int8) 0x04, (int8) 0x22, (int8) 0x02, (int8) 0x00, (int8) 0x0C, (int8) 0x28, (int8) 0x1A, (int8) 0x30, (int8) 0x06, (int8) 0x82,
            (int8) 0xF4, (int8) 0x03, (int8) 0x03, (int8) 0x4F, (int8) 0x52, (int8) 0x43, (int8) 0x17
        };
        return b;
    }

    @Test
    public void parsesCompressedFooter() {
        int8[] f = OrcCompressedTest.zlibOrc();
        OrcMetadata m = OrcMetadata.parse(f, (int64) f.count());
        Assert.that((int64) m.compression).isEqualTo((int64) 1);   // ZLIB
        Assert.that(m.numberOfRows).isEqualTo((int64) 8);
        Assert.that((int64) m.stripeCount).isEqualTo((int64) 1);
        return;
    }

    @Test
    public void readsCompressedColumn() {
        int8[] f = OrcCompressedTest.zlibOrc();
        int64 sum = OrcColumnReader.int32ColumnSum(f, (int64) f.count(), 1);
        Assert.that(sum).isEqualTo((int64) 180);   // 5+10+...+40
        return;
    }

    @Test
    public void readsCompressedColumnByName() {
        int8[] f = OrcCompressedTest.zlibOrc();
        int64 sum = OrcColumnReader.int32ColumnSumByName(f, (int64) f.count(), "x");
        Assert.that(sum).isEqualTo((int64) 180);
        return;
    }

