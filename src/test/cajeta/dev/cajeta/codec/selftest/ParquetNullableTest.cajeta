    @Test
    public void intValidityMask() {
        int8[] f = ParquetNullableTest.nullableParquet();
        boolean[] valid = ParquetColumnReader.readValidity(f, (int64) f.count(), 0);
        Assert.that((int64) valid.count()).isEqualTo((int64) 5);
        Assert.isTrue(valid[0]);
        Assert.isFalse(valid[1]);
        Assert.isTrue(valid[2]);
        Assert.isFalse(valid[3]);
        Assert.isTrue(valid[4]);
        return;
    }

    @Test
    public void intPresentValuesLandAtValidRows() {
        int8[] f = ParquetNullableTest.nullableParquet();
        int32[] v = ParquetColumnReader.readInt32Column(f, (int64) f.count(), 0);
        Assert.that((int64) v.count()).isEqualTo((int64) 5);
        Assert.that((int64) v[0]).isEqualTo((int64) 1);
        Assert.that((int64) v[2]).isEqualTo((int64) 3);
        Assert.that((int64) v[4]).isEqualTo((int64) 5);
        return;
    }

    @Test
    public void stringValidityAndValues() {
        int8[] f = ParquetNullableTest.nullableParquet();
        boolean[] valid = ParquetColumnReader.readValidity(f, (int64) f.count(), 1);
        Assert.isTrue(valid[0]);
        Assert.isFalse(valid[1]);
        Assert.isFalse(valid[2]);
        Assert.isTrue(valid[3]);
        Assert.isTrue(valid[4]);
        String[] v = ParquetColumnReader.readStringColumn(f, (int64) f.count(), 1);
        Assert.equals("x", v[0]);
        Assert.equals("yz", v[3]);
        Assert.equals("w", v[4]);
        return;
    }
