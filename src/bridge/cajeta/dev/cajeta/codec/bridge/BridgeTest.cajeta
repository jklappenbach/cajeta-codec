            (int8) 0x32, (int8) 0x34, (int8) 0x2E, (int8) 0x30, (int8) 0x2E, (int8) 0x30, (int8) 0x19, (int8) 0x4C, (int8) 0x1C, (int8) 0x00, (int8) 0x00, (int8) 0x1C,
            (int8) 0x00, (int8) 0x00, (int8) 0x1C, (int8) 0x00, (int8) 0x00, (int8) 0x1C, (int8) 0x00, (int8) 0x00, (int8) 0x00, (int8) 0xC7, (int8) 0x04, (int8) 0x00,
            (int8) 0x00, (int8) 0x50, (int8) 0x41, (int8) 0x52, (int8) 0x31
        };
        return #b;
    }

    // Split each export bundle into its (schema, array) address pair.
    static void split(DynCol[] cols, int32 nc, int64[] sc, int64[] ar) {
        ArrowFfi f = stack ArrowFfi();
        int32 i = 0;
        while (i < nc) {
            int64 b = cols[i].exportArrow();
            sc[i] = b;
            ar[i] = f.bundleArrayAddr(b);
            i = i + 1;
        }
        return;
    }

    @Test
    public void parquetCrossesArrowIntoTypedTable() {
        int8[] f = BridgeTest.tickParquet();
        int64 fc = (int64) f.count();
        DynCol[] cols = ParquetArrow.readColumns(f, fc, 4);
        int64[] sc = heap int64[4];
        int64[] ar = heap int64[4];
        BridgeTest.split(cols, 4, sc, ar);

        Table<Tick> t = Table.importArrow<Tick>(sc, ar, 4);
        Assert.that(t.rowCount()).isEqualTo((int64) 6);

        // non-null int64 key + double, spanning both row groups
        Assert.that(t.ts.get(0)).isEqualTo((int64) 1);
        Assert.that(t.ts.get(5)).isEqualTo((int64) 6);
        Assert.thatFloat(t.price.get(0)).isCloseTo((float64) 10.5, (float64) 0.0000001);
        Assert.thatFloat(t.price.get(5)).isCloseTo((float64) 15.5, (float64) 0.0000001);

        // nullable column: missing at rows 1 and 3, present elsewhere
        Assert.isTrue(t.lot.isValid(0));
        Assert.that(t.lot.get(0)).isEqualTo((int64) 100);
        Assert.isFalse(t.lot.isValid(1));
        Assert.isFalse(t.lot.isValid(3));
        Assert.isTrue(t.lot.isValid(4));
        Assert.that(t.lot.get(4)).isEqualTo((int64) 500);

        // strings
        Assert.equals("NYSE", t.venue.get(0));
        Assert.equals("ARCA", t.venue.get(3));
        Assert.equals("NYSE", t.venue.get(5));

        // keep the source columns alive across the import/reads (export borrows)
        Assert.that((int64) cols.count()).isEqualTo((int64) 4);
        return;
    }

    @Test
    public void schemaMismatchFailsLoud() {
        int8[] f = BridgeTest.tickParquet();
        int64 fc = (int64) f.count();
        DynCol[] cols = ParquetArrow.readColumns(f, fc, 4);
        int64[] sc = heap int64[4];
        int64[] ar = heap int64[4];
        BridgeTest.split(cols, 4, sc, ar);

        boolean caught = false;
        try {
            // TickBad wants int64 `price`; the file's column is double — the
            // rebind's asI64 rejects it, naming the actual column type.
            Table<TickBad> t = Table.importArrow<TickBad>(sc, ar, 4);
        } catch (ColumnTypeException e) {
            caught = true;
        }
        Assert.isTrue(caught);
        Assert.that((int64) cols.count()).isEqualTo((int64) 4);
        return;
    }
}
