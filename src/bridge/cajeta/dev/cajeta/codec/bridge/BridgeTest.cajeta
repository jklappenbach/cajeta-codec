package dev.cajeta.codec.bridge;

import dev.cajeta.unit.Assert;
import cajeta.lang.Utf8;
import cajeta.nucleo.frame.Table;
import cajeta.nucleo.column.DynCol;
import cajeta.nucleo.column.ArrowFfi;
import cajeta.nucleo.column.ColumnTypeException;

// The typed record the parquet Tick fixture imports into (U17 bridge). Field
// order + types match the pyarrow-written file column-for-column: non-null
// int64, non-null double, NULLABLE int64, non-null utf8. Records are co-located
// with the first Table<R> instantiation on purpose: a record resolved from a
// SEPARATE compilation file is not materialized as a record before Table<R>'s
// schema check runs (a cross-file class-loader gap in the toolchain), so the
// schema descriptor must live beside its use.
public record Tick {
    int64 ts;
    float64 price;
    @Nullable int64 lot;
    Utf8 venue;
}

// Deliberately mismatched: `price` int64 where the file column is DOUBLE — the
// positional rebind must reject it rather than reinterpret bits.
public record TickBad {
    int64 ts;
    int64 price;
    @Nullable int64 lot;
    Utf8 venue;
}

/**
 * U17 — the cross-repo integration: a pyarrow-written parquet file crosses the
 * Arrow C Data Interface into a typed Table. The fixture (row_group_size=4 ->
 * TWO row groups) carries every physical class plus a nullable column + strings:
 *   ts    (int64,  non-null) = [1,2,3,4,5,6]
 *   price (double, non-null) = [10.5,11.5,12.5,13.5,14.5,15.5]
 *   lot   (int64,  NULLABLE) = [100,null,300,null,500,600]
 *   venue (utf8,   non-null) = ["NYSE","NASDAQ","NYSE","ARCA","NASDAQ","NYSE"]
 * Parquet decode -> ParquetArrow DynCols -> exportArrow -> the SAME seam
 * Table.importArrow<R> consumes. Column mismatch fails loud.
 */
public class BridgeTest {

