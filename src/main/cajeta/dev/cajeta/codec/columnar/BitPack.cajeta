package dev.cajeta.codec.columnar;

/**
 * Bit-packing primitive (Phase 6.1a) — the shared columnar building block under
 * Parquet's RLE/bit-packing hybrid and ORC's encodings. Values of a fixed bit
 * width `w` (0..32) are packed **LSB-first**: value `i` occupies bits
 * `[i*w, (i+1)*w)` of the little-endian bit stream, low bit of each value first.
 *
 * This scalar decoder is bit-exact and serves as the v1 kernel *and* the oracle
 * the SIMD-BP128 vectorization (parked, P-COLUMNAR-SIMD) must match.
 */
public final class BitPack {

    /**
     * Unpack `count` width-`w` values starting at bit offset `bitOff` into `src`.
     * `w == 0` decodes all-zeros (a common RLE degenerate). Caller owns the result.
     */
    public static #int32[] unpack(int8[] src, int64 bitOff, int32 w, int32 count) {
        int32[] out = heap int32[count];
        if (w == 0) {
            int32 z = 0;
            while (z < count) { out[z] = 0; z = z + 1; }
            return #out;
        }
        int64 bp = bitOff;
        int32 i = 0;
        while (i < count) {
            int32 val = 0;
            int32 b = 0;
            while (b < w) {
                int64 byteIdx = bp >> 3;
                int32 bitIdx = (int32) (bp & (int64) 7);
                int32 byteVal = ((int32) src[byteIdx]) & 0xFF;
                int32 bit = (byteVal >> bitIdx) & 1;
                val = val | (bit << b);
                bp = bp + 1;
                b = b + 1;
            }
            out[i] = val;
            i = i + 1;
        }
        return #out;
    }

    /** Byte length of `count` width-`w` packed values, rounded up to whole bytes. */
    public static int64 packedBytes(int32 w, int32 count) {
        int64 bits = (int64) w * (int64) count;
        return (bits + (int64) 7) >> 3;
    }

    /**
     * Pack `count` width-`w` values (LSB-first) into a fresh byte array, the
     * inverse of `unpack`. Caller owns the result.
     */
    public static #int8[] pack(int32[] values, int32 w, int32 count) {
        int64 nbytes = BitPack.packedBytes(w, count);
        int8[] out = heap int8[nbytes];
        int64 z = (int64) 0;
        while (z < nbytes) { out[z] = (int8) 0; z = z + 1; }
        if (w == 0) { return out; }
        int64 bp = (int64) 0;
        int32 i = 0;
        while (i < count) {
            int32 v = values[i];
            int32 b = 0;
            while (b < w) {
                int32 bit = (v >> b) & 1;
                if (bit != 0) {
                    int64 byteIdx = bp >> 3;
                    int32 bitIdx = (int32) (bp & (int64) 7);
                    int32 cur = ((int32) out[byteIdx]) & 0xFF;
                    out[byteIdx] = (int8) (cur | (1 << bitIdx));
                }
                bp = bp + 1;
                b = b + 1;
            }
            i = i + 1;
        }
        return #out;
    }

    /** Minimum bit width (0..32) needed to represent the max of `count` values. */
    public static int32 minWidth(int32[] values, int32 count) {
        int32 maxv = 0;
        int32 i = 0;
        while (i < count) {
            int32 v = values[i];
            if (v > maxv) { maxv = v; }
            i = i + 1;
        }
        int32 w = 0;
        while (maxv != 0) { maxv = maxv >> 1; w = w + 1; }
        return w;
    }
}
