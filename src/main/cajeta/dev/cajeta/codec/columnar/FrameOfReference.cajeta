package dev.cajeta.codec.columnar;

/**
 * Frame-of-Reference (FOR) decode (Phase 6.1d). Values are stored as a constant
 * `reference` (typically the column/block min) plus bit-packed residuals
 * `value[i] - reference`, narrowing the bit width. Decode unpacks the residuals
 * via `BitPack` and adds the reference back. The reference is supplied by the
 * format layer (ORC/Parquet block headers); this kernel takes it as a parameter.
 */
public final class FrameOfReference {

    /** The reference (minimum) of `count` values. */
    public static int32 referenceOf(int32[] values, int32 count) {
        if (count == 0) { return 0; }
        int32 m = values[0];
        int32 i = 1;
        while (i < count) {
            if (values[i] < m) { m = values[i]; }
            i = i + 1;
        }
        return m;
    }

    /** Bit-pack residuals `value - reference` at width `w`. */
    public static #int8[] encode(int32[] values, int32 count, int32 reference,
                                 int32 w) {
        int32[] res = heap int32[count];
        int32 i = 0;
        while (i < count) {
            res[i] = values[i] - reference;
            i = i + 1;
        }
        return BitPack.pack(res, w, count);
    }

    public static #int32[] decode(int8[] src, int64 byteOff, int32 w,
                                  int32 count, int32 reference) {
        int32[] residuals = BitPack.unpack(src, byteOff << 3, w, count);
        int32[] out = heap int32[count];
        int32 i = 0;
        while (i < count) {
            out[i] = residuals[i] + reference;
            i = i + 1;
        }
        return out;
    }
}
