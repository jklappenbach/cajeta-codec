package dev.cajeta.codec.columnar;

/**
 * Parquet RLE / bit-packing **hybrid** decode (Phase 6.1b) — the dominant Parquet
 * encoding (definition/repetition levels, dictionary indices, boolean columns).
 * The stream is a sequence of runs, each prefixed by a ULEB128 header:
 *   - header & 1 == 1 → **bit-packed** run of `(header >> 1)` groups of 8 values,
 *     each width `w` (LSB-first via `BitPack`);
 *   - header & 1 == 0 → **RLE** run repeating one `ceil(w/8)`-byte little-endian
 *     value `(header >> 1)` times.
 * `w` is fixed for the stream. Decoding stops once `count` values are produced
 * (the final bit-packed group may carry padding values, which are ignored).
 */
public final class Rle {

    static int64 writeUleb(int8[] buf, int64 o, int64 v) {
        int64 t = v;
        while (t >= (int64) 128) {
            buf[o] = (int8) ((t & (int64) 0x7F) | (int64) 0x80);
            o = o + 1;
            t = t >> 7;
        }
        buf[o] = (int8) (t & (int64) 0x7F);
        o = o + 1;
        return o;
    }

    /**
     * Encode `count` width-`w` values as a hybrid stream: one RLE run if all
     * values are equal, else a single bit-packed run of `ceil(count/8)` groups
     * (padded with zeros). Both are spec-valid; round-trips with `decode`.
     */
    public static #int8[] encode(int32[] values, int32 w, int32 count) {
        int64 cap = (int64) 32 + BitPack.packedBytes(w, count);
        int8[] buf = heap int8[cap];
        int64 o = (int64) 0;
        boolean allSame = count > 0;
        int32 v0 = 0;
        if (count > 0) {
            v0 = values[0];
            int32 i = 1;
            while (i < count) {
                if (values[i] != v0) { allSame = false; }
                i = i + 1;
            }
        }
        if (allSame) {
            int64 header = ((int64) count) << 1;       // RLE run: LSB=0
            o = Rle.writeUleb(buf, o, header);
            int32 byteW = (w + 7) / 8;
            int32 k = 0;
            while (k < byteW) {
                buf[o] = (int8) ((v0 >> (k * 8)) & 0xFF);
                o = o + 1;
                k = k + 1;
            }
        } else {
            int32 groups = (count + 7) / 8;
            int32 n = groups * 8;
            int64 header = (((int64) groups) << 1) | (int64) 1;   // bit-packed: LSB=1
            o = Rle.writeUleb(buf, o, header);
            int32[] padded = heap int32[n];
            int32 i = 0;
            while (i < count) { padded[i] = values[i]; i = i + 1; }
            while (i < n) { padded[i] = 0; i = i + 1; }
            int8[] packed = BitPack.pack(padded, w, n);
            int64 pn = (int64) packed.count();
            int64 j = (int64) 0;
            while (j < pn) { buf[o] = packed[j]; o = o + 1; j = j + 1; }
        }
        int8[] r = heap int8[o];
        int64 m = (int64) 0;
        while (m < o) { r[m] = buf[m]; m = m + 1; }
        return #r;
    }

    public static #int32[] decode(int8[] src, int64 off, int32 w, int32 count) {
        int32[] out = heap int32[count];
        int32 produced = 0;
        int64 bp = off;
        while (produced < count) {
            // ULEB128 run header.
            int64 header = (int64) 0;
            int32 shift = 0;
            boolean more = true;
            while (more) {
                int32 byteVal = ((int32) src[bp]) & 0xFF;
                bp = bp + 1;
                int64 chunk = (int64) (byteVal & 0x7F);
                header = header | (chunk << shift);
                if ((byteVal & 0x80) == 0) { more = false; }
                shift = shift + 7;
            }
            int64 mode = header & (int64) 1;
            int64 runLen = header >> 1;
            if (mode == (int64) 1) {
                // bit-packed run (LSB=1): runLen groups of 8 (Parquet convention).
                int32 n = (int32) (runLen * (int64) 8);
                int32[] vals = BitPack.unpack(src, bp << 3, w, n);
                bp = bp + BitPack.packedBytes(w, n);
                int32 k = 0;
                while (k < n) {
                    if (produced < count) {
                        out[produced] = vals[k];
                        produced = produced + 1;
                    }
                    k = k + 1;
                }
            } else {
                int32 byteW = (w + 7) / 8;
                int32 value = 0;
                int32 bidx = 0;
                while (bidx < byteW) {
                    int64 si = bp + (int64) bidx;
                    int32 bv = ((int32) src[si]) & 0xFF;
                    value = value | (bv << (bidx * 8));
                    bidx = bidx + 1;
                }
                bp = bp + (int64) byteW;
                int32 rl = (int32) runLen;
                int32 r = 0;
                while (r < rl) {
                    if (produced < count) {
                        out[produced] = value;
                        produced = produced + 1;
                    }
                    r = r + 1;
                }
            }
        }
        return #out;
    }
}
