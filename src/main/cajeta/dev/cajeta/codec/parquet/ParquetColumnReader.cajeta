package dev.cajeta.codec.parquet;

import dev.cajeta.codec.columnar.Rle;

/**
 * Parquet single-column reader (Phase 7.1c). Reads one INT32 column's values from
 * the first row group: walks the footer for the column's data-page offset, type,
 * codec, and (from the schema) repetition type; parses the v1 `PageHeader`; then
 * decodes the data page — definition levels (RLE/bit-packing hybrid) + PLAIN
 * INT32 values. UNCOMPRESSED only here; compressed pages + dictionary/RLE value
 * encodings + null handling land in 7.3. One `ThriftCompactReader` over the file
 * (its constructor consumes the buffer, so a single reader is reused via `seek`).
 */
public final class ParquetColumnReader {

    static int32 bitsFor(int32 maxVal) {
        int32 w = 0;
        int32 v = maxVal;
        while (v > 0) { v = v >> 1; w = w + 1; }
        return w;
    }

    public static #int32[] readInt32Column(int8[] file, int64 n, int32 col) {
        int64 footerOff = ParquetMetadata.footerOffset(file, n);
        ThriftCompactReader r = heap ThriftCompactReader(file, footerOff);

        int64 dataPageOffset = (int64) 0;
        int32 codec = 0;
        int32 colType = 0;
        int64 numValues = (int64) 0;
        int32 repType = 0;            // 0=REQUIRED, 1=OPTIONAL, 2=REPEATED

        r.enterStruct();
        int32 t = r.readFieldHeader();
        while (t != (int32) 0) {
            int32 fid = r.fieldId();
            if (fid == 2) {
                // schema: list<SchemaElement>; element col+1 is the column.
                int32 nEl = r.readListHeader();
                int32 want = col + 1;
                int32 e = 0;
                while (e < nEl) {
                    if (e != want) {
                        r.skip((int32) 12);
                    } else {
                        int32 seSaved = r.enterStruct();
                        int32 st = r.readFieldHeader();
                        while (st != (int32) 0) {
                            int32 sfid = r.fieldId();
                            if (sfid == 3) {
                                repType = r.readI32();
                            } else {
                                r.skip(st);
                            }
                            st = r.readFieldHeader();
                        }
                        r.exitStruct(seSaved);
                    }
                    e = e + 1;
                }
            } else if (fid == 4) {
                int32 nGroups = r.readListHeader();
                int32 g = 0;
                while (g < nGroups) {
                    if (g != 0) {
                        r.skip((int32) 12);
                    } else {
                        int32 rgSaved = r.enterStruct();
                        int32 rt = r.readFieldHeader();
                        while (rt != (int32) 0) {
                            int32 rfid = r.fieldId();
                            if (rfid == 1) {
                                int32 nCols = r.readListHeader();
                                int32 c = 0;
                                while (c < nCols) {
                                    if (c != col) {
                                        r.skip((int32) 12);
                                    } else {
                                        int32 ccSaved = r.enterStruct();
                                        int32 ct = r.readFieldHeader();
                                        while (ct != (int32) 0) {
                                            int32 cfid = r.fieldId();
                                            if (cfid == 3) {
                                                int32 cmSaved = r.enterStruct();
                                                int32 mt = r.readFieldHeader();
                                                while (mt != (int32) 0) {
                                                    int32 mfid = r.fieldId();
                                                    if (mfid == 1) {
                                                        colType = r.readI32();
                                                    } else if (mfid == 4) {
                                                        codec = r.readI32();
                                                    } else if (mfid == 5) {
                                                        numValues = r.readI64();
                                                    } else if (mfid == 9) {
                                                        dataPageOffset = r.readI64();
                                                    } else {
                                                        r.skip(mt);
                                                    }
                                                    mt = r.readFieldHeader();
                                                }
                                                r.exitStruct(cmSaved);
                                            } else {
                                                r.skip(ct);
                                            }
                                            ct = r.readFieldHeader();
                                        }
                                        r.exitStruct(ccSaved);
                                    }
                                    c = c + 1;
                                }
                            } else {
                                r.skip(rt);
                            }
                            rt = r.readFieldHeader();
                        }
                        r.exitStruct(rgSaved);
                    }
                    g = g + 1;
                }
            } else {
                r.skip(t);
            }
            t = r.readFieldHeader();
        }

        if (colType != 1) {
            throw heap ParquetParseException("column is not INT32 (v1)", dataPageOffset);
        }
        if (codec != 0) {
            throw heap ParquetParseException("compressed pages land in 7.3", dataPageOffset);
        }

        // Parse the v1 PageHeader at the data-page offset.
        r.seek(dataPageOffset);
        int32 saved = r.enterStruct();
        int32 compSize = 0;
        int32 pageNumValues = 0;
        int32 encoding = 0;
        int32 pt = r.readFieldHeader();
        while (pt != (int32) 0) {
            int32 pfid = r.fieldId();
            if (pfid == 1) {
                r.readI32();                 // page type (DATA_PAGE)
            } else if (pfid == 2) {
                r.readI32();                 // uncompressed_page_size
            } else if (pfid == 3) {
                compSize = r.readI32();
            } else if (pfid == 5) {
                int32 dphSaved = r.enterStruct();
                int32 dt = r.readFieldHeader();
                while (dt != (int32) 0) {
                    int32 dfid = r.fieldId();
                    if (dfid == 1) {
                        pageNumValues = r.readI32();
                    } else if (dfid == 2) {
                        encoding = r.readI32();
                    } else {
                        r.skip(dt);
                    }
                    dt = r.readFieldHeader();
                }
                r.exitStruct(dphSaved);
            } else {
                r.skip(pt);
            }
            pt = r.readFieldHeader();
        }
        r.exitStruct(saved);

        if (encoding != 0) {
            throw heap ParquetParseException(
                "non-PLAIN value encoding lands in 7.3", dataPageOffset);
        }
        if (repType == 2) {
            throw heap ParquetParseException(
                "repeated/nested columns land in 7.3", dataPageOffset);
        }

        int64 dataStart = r.position();
        int8[] page = r.slice(dataStart, (int64) compSize);

        // v1 page layout: [rep levels?][def levels?][PLAIN values]. Flat column ⇒
        // no rep levels. OPTIONAL ⇒ a 4-byte-LE-prefixed def-level section; the
        // value plane follows. v1 assumes no nulls (every value present) — null
        // masks via def-level decode land in 7.3.
        int64 valuesStart = (int64) 0;
        if (repType == 1) {
            int64 defLen = ParquetColumnReader.le32(page, (int64) 0);
            valuesStart = (int64) 4 + defLen;
        }

        int32[] vals = heap int32[pageNumValues];
        int64 vp = valuesStart;
        int32 i = 0;
        while (i < pageNumValues) {
            int64 v = ParquetColumnReader.le32(page, vp);
            vals[i] = (int32) v;
            vp = vp + (int64) 4;
            i = i + 1;
        }
        return #vals;
    }

    static int64 le32(int8[] b, int64 at) {
        int64 b0 = (int64) (((int32) b[at]) & 0xFF);
        int64 a1 = at + (int64) 1;
        int64 a2 = at + (int64) 2;
        int64 a3 = at + (int64) 3;
        int64 b1 = (int64) (((int32) b[a1]) & 0xFF);
        int64 b2 = (int64) (((int32) b[a2]) & 0xFF);
        int64 b3 = (int64) (((int32) b[a3]) & 0xFF);
        return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    }
}
