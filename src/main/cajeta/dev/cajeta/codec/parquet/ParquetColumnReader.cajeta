package dev.cajeta.codec.parquet;

import dev.cajeta.codec.columnar.Rle;
import dev.cajeta.codec.compress.Snappy;
import dev.cajeta.codec.compress.Gzip;

/**
 * Parquet single-column reader (Phase 7.1c + 7.3). Reads one INT32 column's
 * values from the first row group, covering real pyarrow files:
 *   - codecs: UNCOMPRESSED, SNAPPY, GZIP (page-level, Phase-4 codecs);
 *   - value encodings: PLAIN and PLAIN_DICTIONARY / RLE_DICTIONARY (dictionary
 *     page → indices via the columnar `Rle` hybrid → `Dictionary.gather`).
 * v1 assumes no nulls (every value present); null masks (def-level decode),
 * multi-row-group spanning, and non-INT32 types are follow-ups (7.3 tail / writer).
 *
 * One `ThriftCompactReader` over the file (its ctor consumes the buffer), reused
 * via `seek` for the footer, the dictionary page, and the data page.
 */
public final class ParquetColumnReader {

    static int64 le32(int8[] b, int64 at) {
        int64 b0 = (int64) (((int32) b[at]) & 0xFF);
        int64 a1 = at + (int64) 1;
        int64 a2 = at + (int64) 2;
        int64 a3 = at + (int64) 3;
        int64 b1 = (int64) (((int32) b[a1]) & 0xFF);
        int64 b2 = (int64) (((int32) b[a2]) & 0xFF);
        int64 b3 = (int64) (((int32) b[a3]) & 0xFF);
        return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    }

    // PLAIN fixed-width values (4-byte INT32/FLOAT or 8-byte INT64/DOUBLE),
    // little-endian, widened into int64 (FLOAT/DOUBLE carry raw bits).
    static #int64[] readPlainLongs(int8[] page, int64 start, int32 count,
                                   int32 bytes) {
        int64[] out = heap int64[count];
        int64 vp = start;
        int32 i = 0;
        while (i < count) {
            int64 v = (int64) 0;
            int32 k = 0;
            while (k < bytes) {
                int64 bi = vp + (int64) k;
                int64 bb = (int64) (((int32) page[bi]) & 0xFF);
                v = v | (bb << (k * 8));
                k = k + 1;
            }
            out[i] = v;
            vp = vp + (int64) bytes;
            i = i + 1;
        }
        return out;
    }

    static #int8[] decompress(int8[] comp, int64 compSize, int32 codec,
                              int64 uncompSize) {
        if (codec == 0) {
            int8[] raw = heap int8[compSize];
            int64 k = (int64) 0;
            while (k < compSize) { raw[k] = comp[k]; k = k + 1; }
            return raw;
        }
        if (codec == 1) {
            return Snappy.decompress(comp, compSize);
        }
        if (codec == 2) {
            return Gzip.decompress(comp, compSize);
        }
        throw heap ParquetParseException("unsupported page codec (v1)", (int64) 0);
    }

    // Core reader: returns column values widened into int64 (raw bits for
    // FLOAT/DOUBLE). Per-type wrappers narrow/reinterpret.
    static #int64[] readLongs(int8[] file, int64 n, int32 col) {
        int64 footerOff = ParquetMetadata.footerOffset(file, n);
        ThriftCompactReader r = heap ThriftCompactReader(file, footerOff);

        int64 dataPageOffset = (int64) 0;
        int64 dictPageOffset = (int64) 0 - (int64) 1;
        int32 codec = 0;
        int32 colType = 0;
        int32 repType = 0;

        r.enterStruct();
        int32 t = r.readFieldHeader();
        while (t != (int32) 0) {
            int32 fid = r.fieldId();
            if (fid == 2) {
                int32 nEl = r.readListHeader();
                int32 want = col + 1;
                int32 e = 0;
                while (e < nEl) {
                    if (e != want) {
                        r.skip((int32) 12);
                    } else {
                        int32 seSaved = r.enterStruct();
                        int32 st = r.readFieldHeader();
                        while (st != (int32) 0) {
                            if (r.fieldId() == 3) {
                                repType = r.readI32();
                            } else {
                                r.skip(st);
                            }
                            st = r.readFieldHeader();
                        }
                        r.exitStruct(seSaved);
                    }
                    e = e + 1;
                }
            } else if (fid == 4) {
                int32 nGroups = r.readListHeader();
                int32 g = 0;
                while (g < nGroups) {
                    if (g != 0) {
                        r.skip((int32) 12);
                    } else {
                        int32 rgSaved = r.enterStruct();
                        int32 rt = r.readFieldHeader();
                        while (rt != (int32) 0) {
                            if (r.fieldId() == 1) {
                                int32 nCols = r.readListHeader();
                                int32 c = 0;
                                while (c < nCols) {
                                    if (c != col) {
                                        r.skip((int32) 12);
                                    } else {
                                        int32 ccSaved = r.enterStruct();
                                        int32 ct = r.readFieldHeader();
                                        while (ct != (int32) 0) {
                                            if (r.fieldId() == 3) {
                                                int32 cmSaved = r.enterStruct();
                                                int32 mt = r.readFieldHeader();
                                                while (mt != (int32) 0) {
                                                    int32 mfid = r.fieldId();
                                                    if (mfid == 1) {
                                                        colType = r.readI32();
                                                    } else if (mfid == 4) {
                                                        codec = r.readI32();
                                                    } else if (mfid == 9) {
                                                        dataPageOffset = r.readI64();
                                                    } else if (mfid == 11) {
                                                        dictPageOffset = r.readI64();
                                                    } else {
                                                        r.skip(mt);
                                                    }
                                                    mt = r.readFieldHeader();
                                                }
                                                r.exitStruct(cmSaved);
                                            } else {
                                                r.skip(ct);
                                            }
                                            ct = r.readFieldHeader();
                                        }
                                        r.exitStruct(ccSaved);
                                    }
                                    c = c + 1;
                                }
                            } else {
                                r.skip(rt);
                            }
                            rt = r.readFieldHeader();
                        }
                        r.exitStruct(rgSaved);
                    }
                    g = g + 1;
                }
            } else {
                r.skip(t);
            }
            t = r.readFieldHeader();
        }

        int32 valueBytes = 8;
        if (colType == 1 || colType == 4) {
            valueBytes = 4;                       // INT32 / FLOAT
        } else if (colType == 2 || colType == 5) {
            valueBytes = 8;                       // INT64 / DOUBLE
        } else {
            throw heap ParquetParseException(
                "unsupported physical type (v1: INT32/INT64/FLOAT/DOUBLE)", dataPageOffset);
        }
        if (repType == 2) {
            throw heap ParquetParseException("repeated/nested columns -> 7.3", dataPageOffset);
        }


        // --- dictionary page (optional) ---
        int64[] dict = heap int64[0];
        boolean hasDict = dictPageOffset >= (int64) 0;
        if (hasDict) {
            r.seek(dictPageOffset);
            int32 dSaved = r.enterStruct();
            int32 dComp = 0;
            int32 dUncomp = 0;
            int32 dNum = 0;
            int32 dpt = r.readFieldHeader();
            while (dpt != (int32) 0) {
                int32 pf = r.fieldId();
                if (pf == 2) {
                    dUncomp = r.readI32();
                } else if (pf == 3) {
                    dComp = r.readI32();
                } else if (pf == 7) {
                    int32 dhSaved = r.enterStruct();
                    int32 dh = r.readFieldHeader();
                    while (dh != (int32) 0) {
                        if (r.fieldId() == 1) {
                            dNum = r.readI32();
                        } else {
                            r.skip(dh);
                        }
                        dh = r.readFieldHeader();
                    }
                    r.exitStruct(dhSaved);
                } else {
                    r.skip(dpt);
                }
                dpt = r.readFieldHeader();
            }
            r.exitStruct(dSaved);
            int64 dStart = r.position();
            int8[] dCompBytes = r.slice(dStart, (int64) dComp);
            int8[] dPage = ParquetColumnReader.decompress(
                dCompBytes, (int64) dComp, codec, (int64) dUncomp);
            dict = ParquetColumnReader.readPlainLongs(dPage, (int64) 0, dNum, valueBytes);
        }

        // --- data page ---
        r.seek(dataPageOffset);
        int32 pSaved = r.enterStruct();
        int32 compSize = 0;
        int32 uncompSize = 0;
        int32 pageNumValues = 0;
        int32 encoding = 0;
        int32 pt = r.readFieldHeader();
        while (pt != (int32) 0) {
            int32 pfid = r.fieldId();
            if (pfid == 2) {
                uncompSize = r.readI32();
            } else if (pfid == 3) {
                compSize = r.readI32();
            } else if (pfid == 5) {
                int32 dphSaved = r.enterStruct();
                int32 dt = r.readFieldHeader();
                while (dt != (int32) 0) {
                    int32 dfid = r.fieldId();
                    if (dfid == 1) {
                        pageNumValues = r.readI32();
                    } else if (dfid == 2) {
                        encoding = r.readI32();
                    } else {
                        r.skip(dt);
                    }
                    dt = r.readFieldHeader();
                }
                r.exitStruct(dphSaved);
            } else {
                r.skip(pt);
            }
            pt = r.readFieldHeader();
        }
        r.exitStruct(pSaved);

        int64 dataStart = r.position();
        int8[] compBytes = r.slice(dataStart, (int64) compSize);
        int8[] page = ParquetColumnReader.decompress(
            compBytes, (int64) compSize, codec, (int64) uncompSize);

        // def levels: flat column ⇒ no rep levels; OPTIONAL ⇒ 4-byte-LE-prefixed
        // section. v1 assumes no nulls, so just skip to the value plane.
        int64 valuesStart = (int64) 0;
        if (repType == 1) {
            int64 defLen = ParquetColumnReader.le32(page, (int64) 0);
            valuesStart = (int64) 4 + defLen;
        }

        if (encoding == 0) {
            return ParquetColumnReader.readPlainLongs(
                page, valuesStart, pageNumValues, valueBytes);
        }
        if (encoding == 2 || encoding == 8) {
            // dictionary indices: 1-byte width + RLE/bit-packing hybrid.
            int32 width = ((int32) page[valuesStart]) & 0xFF;
            int64 idxStart = valuesStart + (int64) 1;
            int32[] idx = Rle.decode(page, idxStart, width, pageNumValues);
            int64[] out = heap int64[pageNumValues];
            int32 gi = 0;
            while (gi < pageNumValues) {
                int32 ix = idx[gi];
                out[gi] = dict[ix];
                gi = gi + 1;
            }
            return out;
        }
        throw heap ParquetParseException("unsupported value encoding (v1)", dataPageOffset);
    }

    /** Read an INT32 column (narrows the widened values). */
    public static #int32[] readInt32Column(int8[] file, int64 n, int32 col) {
        int64[] longs = ParquetColumnReader.readLongs(file, n, col);
        int32 m = (int32) longs.count();
        int32[] out = heap int32[m];
        int32 i = 0;
        while (i < m) { out[i] = (int32) longs[i]; i = i + 1; }
        return out;
    }

    /** Sum an INT64 column's values (scalar return — validates the int64 path
        without returning an int64[], which miscompiles across the test-exe). */
    public static int64 int64ColumnSum(int8[] file, int64 n, int32 col) {
        int64[] longs = ParquetColumnReader.readLongs(file, n, col);
        int64 sum = (int64) 0;
        int32 m = (int32) longs.count();
        int32 i = 0;
        while (i < m) { sum = sum + longs[i]; i = i + 1; }
        return sum;
    }

    /** Read an INT64 column. */
    public static #int64[] readInt64Column(int8[] file, int64 n, int32 col) {
        int64[] longs = ParquetColumnReader.readLongs(file, n, col);
        int32 m = (int32) longs.count();
        int64[] out = heap int64[m];
        int32 i = 0;
        while (i < m) { out[i] = longs[i]; i = i + 1; }
        return out;
    }
}
